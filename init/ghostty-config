# Font
font-family = MesloLGS NF
font-size = 13
font-style-bold = true
font-style-italic = true

# Colors - matching iTerm vivid palette
background = 000000
foreground = bbbbbb
cursor-color = bbbbbb
cursor-style = block
cursor-style-blink = false
selection-foreground = 000000
selection-background = b5d5ff

# ANSI colors (normal)
palette = 0=#000000
palette = 1=#bb0000
palette = 2=#00bb00
palette = 3=#bbbb00
palette = 4=#0000bb
palette = 5=#bb00bb
palette = 6=#00bbbb
palette = 7=#bbbbbb

# ANSI colors (bright)
palette = 8=#555555
palette = 9=#ff5555
palette = 10=#55ff55
palette = 11=#ffff55
palette = 12=#5555ff
palette = 13=#ff55ff
palette = 14=#55ffff
palette = 15=#ffffff

bold-is-bright = true

# Window
background-opacity = 0.85
background-blur = 20
window-padding-x = 2
window-padding-y = 2

# Terminal
term = xterm-256color
scrollback-limit = 10000000

# Bell - no audio, just title indicator
bell-features = title

# Option key as Alt (for word jumping: alt-b, alt-f)
macos-option-as-alt = true

# macOS native feel
macos-titlebar-style = tabs
window-decoration = true

# Clipboard
clipboard-read = allow
clipboard-write = allow

# Mouse
mouse-hide-while-typing = true

# Cycle splits with Ctrl+Tab
keybind = ctrl+tab=goto_split:next
keybind = ctrl+shift+tab=goto_split:previous

# No confirmation on close
confirm-close-surface = false

# Dim unfocused splits for clear focus indication
unfocused-split-opacity = 0.5

# Keep zoom state when cycling between splits
split-preserve-zoom = navigation

# Copy on select
copy-on-select = clipboard
